{
  "name": "emvcode",
  "version": "0.1.0",
  "description": "EMVCo dev tools",
  "keywords": [
    "EMVCo",
    "payment",
    "card",
    "typescript"
  ],
  "license": "MIT",
  "author": "Juan Bautista",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc && node scripts/obfuscate.js",
    "test": "jest --clearCache && jest --coverage",
