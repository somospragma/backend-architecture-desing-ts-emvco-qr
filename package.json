{
  "name": "@pragmasa/emvcode",
  "version": "1.0.0",
  "description": "EMVCo dev tools",
  "keywords": [
    "EMVCo",
    "payment",
    "card",
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "Juan Bautista",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "restricted"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc && node scripts/obfuscate.js",
    "test": "jest --clearCache && jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "dev": "ts-node src/index.ts",
    "obfuscate": "node scripts/obfuscate.js"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "dijkstrajs": "1.0.3"
  },
  "devDependencies": {
    "@types/jest": "29.5.0",
    "@types/node": "20.0.0",
    "javascript-obfuscator": "5.1.0",
    "jest": "29.5.0",
    "rimraf": "5.0.0",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.0",
    "typescript": "5.0.4"
  }
}
